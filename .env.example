# Aqueduct 环境变量模板
# 复制为 .env 后填入实际值：cp .env.example .env

# === LLM API 配置（必填） ===
# API 基础 URL — Anthropic 官方：https://api.anthropic.com
# 或公司内部代理地址
ANTHROPIC_BASE_URL=

# API 密钥 — Anthropic 官方 key 或公司内部认证 token
ANTHROPIC_AUTH_TOKEN=

# === 模型标识（可选，默认使用环境变量中的模型） ===
# 轻量分析模型（Haiku 档）— 需求解析、统计、召回
# ANTHROPIC_DEFAULT_HAIKU_MODEL=claude-haiku-4-5
# 中等生成模型（Sonnet 档）— 方案编写、DDL 生成
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-6
# 重度生成模型（Opus 档）— SQL 生成、质检、CodeReview
# ANTHROPIC_DEFAULT_OPUS_MODEL=claude-opus-4-7

# === 数据平台配置（DQC 自动执行，可选） ===
# 数据平台基础 URL
# DP_BASE_URL=

# 用户 ID（员工工号）
# DP_USER_ID=

# 认证 Cookie（从浏览器登录后获取）
# DP_COOKIE=

# === SQL 执行能力配置（DQC 自动验证，可选） ===
# 设为 false 可强制禁用执行能力（即使 DP_* 已配置）
# AQUEDUCT_EXECUTION_ENABLED=true
# 单条 SQL 超时（秒）
# AQUEDUCT_EXECUTION_TIMEOUT_SECONDS=300
# 最大返回行数
# AQUEDUCT_EXECUTION_MAX_ROWS=1000

# === 工作流配置（可选） ===
# 审查→修复循环最大迭代次数（Phase 4.5 审查发现问题后自动修复 SQL 的循环次数）
# AQUEDUCT_MAX_FIX_ITERATIONS=2
# LLM 调用超时后最大重试次数（指数退避：600s → 1200s → 2400s）
# AQUEDUCT_LLM_MAX_RETRIES=2
# 外部 SQL 文件路径（非空时 Phase 4 跳过 LLM 生成，直接读取该文件）
# AQUEDUCT_EXTERNAL_SQL_PATH=
